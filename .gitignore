# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# distribution artifact
/rfp-analyzer.zip

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# brainstorm-daily.py outputs — regenerated locally by launchd nightly.
# Committing them would cause merge conflicts with the Claude Code cloud agent.
.brainstorm-state.json
docs/BRAINSTORM_RAW.md
docs/IDEAS_TO_IMPLEMENT.md
# Dated snapshots (IDEAS_TO_IMPLEMENT.YYYY-MM-DD.md) ARE committed — gives stable URLs for GH issue links
docs/DIFF.md
